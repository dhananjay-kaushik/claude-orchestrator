{
  "name": "claude-orchestrator",
  "version": "0.1.1",
  "description": "Stateful Workflow Engine on top of Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claude-orchestrator": "bin/claude-orchestrator.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "orchestrator",
    "cli"
  ],
  "author": "Dhananjay Kaushik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhananjay-kaushik/claude-orchestrator.git"
  },
  "homepage": "https://github.com/dhananjay-kaushik/claude-orchestrator#readme",
  "bugs": {
    "url": "https://github.com/dhananjay-kaushik/claude-orchestrator/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  }
}
